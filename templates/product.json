{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "urgency": {
          "type": "lumu_urgency"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "trust": {
          "type": "trust_badges"
        },
        "description": {
          "type": "description"
        },
        "collapsible-row-0": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Delivery",
            "icon": "truck",
            "content": "<p>We offer free shipping on orders above Rs 2,000 across Pakistan. Standard delivery takes 3-5 business days. Major cities receive orders within 2-3 days.</p>",
            "page": ""
          }
        },
        "collapsible-row-1": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Returns & Exchange",
            "icon": "return",
            "content": "<p>Changed your mind? No worries! We accept returns within 7 days of delivery. Items must be unused and in original packaging. Contact us via WhatsApp for instant support.</p>",
            "page": ""
          }
        },
        "collapsible-row-2": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Quality Guarantee",
            "icon": "check_mark",
            "content": "<p>Every product sold on Lumu is 100% authentic and quality-checked. We work directly with trusted brands and manufacturers to ensure you receive only genuine items.</p>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "variant_picker",
        "quantity_selector",
        "urgency",
        "buy_buttons",
        "trust",
        "description",
        "collapsible-row-0",
        "collapsible-row-1",
        "collapsible-row-2",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "thumbnail_slider",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "product_recommendations": {
      "type": "related-products",
      "settings": {
        "heading": "You May Also Like",
        "heading_size": "h1",
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "portrait",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "custom_reviews": {
      "type": "lumu-product-reviews",
      "settings": {}
    }
  },
  "order": [
    "main",
    "product_recommendations",
    "custom_reviews"
  ]
}
