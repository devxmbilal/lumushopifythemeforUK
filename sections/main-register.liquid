{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'lumu-custom.css' | asset_url | stylesheet_tag }}

<div class="lumu-auth-container">
  <a href="{{ routes.root_url }}">
    <img src="{{ 'lumu2.png' | asset_img_url: '300x' }}" alt="{{ shop.name }}" class="lumu-auth-logo">
  </a>
  
  <h1 class="lumu-auth-title">Create an Account</h1>
  
  {%- form 'create_customer', novalidate: 'novalidate' -%}
    {%- if form.errors -%}
      <div style="color: red; background: #faeded; padding: 15px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; text-align: left;">
        <strong style="display: block; margin-bottom: 5px;">Please fix the following:</strong>
        <ul style="margin: 0; padding-left: 20px;">
          {%- for field in form.errors -%}
            <li>
              {%- if field == 'form' -%}
                {{ form.errors.messages[field] }}
              {%- else -%}
                {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div style="display: flex; gap: 15px;">
      <div class="lumu-auth-field" style="flex: 1;">
        <label for="RegisterForm-FirstName">First Name</label>
        <input
          type="text"
          name="customer[first_name]"
          id="RegisterForm-FirstName"
          {% if form.first_name %}value="{{ form.first_name }}"{% endif %}
          autocomplete="given-name"
          placeholder="First Name"
        >
      </div>
      <div class="lumu-auth-field" style="flex: 1;">
        <label for="RegisterForm-LastName">Last Name</label>
        <input
          type="text"
          name="customer[last_name]"
          id="RegisterForm-LastName"
          {% if form.last_name %}value="{{ form.last_name }}"{% endif %}
          autocomplete="family-name"
          placeholder="Last Name"
        >
      </div>
    </div>

    <div class="lumu-auth-field">
      <label for="RegisterForm-email">Email Address</label>
      <input
        type="email"
        name="customer[email]"
        id="RegisterForm-email"
        {% if form.email %}value="{{ form.email }}"{% endif %}
        spellcheck="false"
        autocapitalize="off"
        autocomplete="email"
        placeholder="name@example.com"
        required
      >
    </div>

    <div class="lumu-auth-field">
      <label for="RegisterForm-password">Password</label>
      <input
        type="password"
        name="customer[password]"
        id="RegisterForm-password"
        placeholder="Create a password"
        required
      >
    </div>

    <button type="submit" class="lumu-auth-btn">
      Create Account
    </button>

    <div class="lumu-auth-footer">
      Already have an account? <a href="{{ routes.account_login_url }}">Sign in</a>
    </div>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "t:sections.main-register.name",
  "settings": []
}
{% endschema %}
