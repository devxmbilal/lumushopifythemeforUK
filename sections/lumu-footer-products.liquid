
<div class="lumu-pre-footer-products">
  <div class="lumu-pfp__inner">
    <div class="lumu-pfp__header">
      <h2 class="lumu-pfp__title">{{ section.settings.title | default: 'Trending Now' }}</h2>
      {%- assign collection_url = "/collections/all" -%}
      {%- if section.settings.collection != blank -%}
        {%- assign collection_url = section.settings.collection.url -%}
      {%- endif -%}
      <a href="{{ collection_url }}" class="lumu-pfp__shop-btn">
        Shop All Products
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
    <div class="lumu-pfp__grid">
      {%- assign selected_products = section.settings.product_list -%}
      {%- assign selected_collection = section.settings.collection -%}
      {%- if selected_products != blank and selected_products.size > 0 -%}
        {%- assign products_list = selected_products -%}
        {%- assign loop_limit = section.settings.products_to_show | default: 4 -%}
        {%- assign loop_offset = 0 -%}
      {%- elsif selected_collection != blank and selected_collection.products.size > 0 -%}
        {%- assign products_list = selected_collection.products -%}
        {%- assign loop_limit = section.settings.products_to_show | default: 4 -%}
        {%- assign loop_offset = 0 -%}
      {%- else -%}
        {%- assign products_list = collections.all.products -%}
        {%- assign loop_limit = section.settings.products_to_show | default: 4 -%}
        {%- assign loop_offset = 8 -%}
      {%- endif -%}
      {%- if products_list.size > 0 -%}
        {%- for product in products_list limit: loop_limit offset: loop_offset -%}
          <div class="lumu-pfp__card-wrapper" style="height: 100%;">
            <a href="{{ product.url }}" class="lumu-pfp__card">
              <div class="lumu-pfp__card-img-wrap">
                {%- if product.featured_image != blank -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600, height: 600, crop: 'center' }}"
                    alt="{{ product.title | escape }}"
                    class="lumu-pfp__card-img"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {%- else -%}
                  <div class="lumu-pfp__card-img" style="background:#f0f0f5;"></div>
                {%- endif -%}
              </div>
              
              <div class="lumu-pfp__card-body">
                <div class="lumu-pfp__reviews">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <span>(4.9)</span>
                </div>
                
                <div class="lumu-pfp__card-name">{{ product.title }}</div>
                
                <div class="lumu-pfp__card-price">
                  {{ product.price | money }}
                  {%- if product.compare_at_price > product.price -%}
                    <s>{{ product.compare_at_price | money }}</s>
                  {%- endif -%}
                </div>
                
                <div class="lumu-pfp__atc-btn">Add to Cart</div>
              </div>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="lumu-pfp__card-wrapper" style="height: 100%;">
            <div class="lumu-pfp__card">
              <div class="lumu-pfp__card-img-wrap">
                <div class="lumu-pfp__card-img" style="background:#f0f0f5;"></div>
              </div>
              <div class="lumu-pfp__card-body">
                <div class="lumu-pfp__reviews">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <span>(5.0)</span>
                </div>
                <div class="lumu-pfp__card-name">Lumu Premium Product {{ i }}</div>
                <div class="lumu-pfp__card-price">Rs 1,999</div>
                <div class="lumu-pfp__atc-btn">Add to Cart</div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Lumu Footer Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Trending Now",
      "label": "Heading"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Select specific products",
      "info": "If selected, overrides the collection option below."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    }
  ],
  "presets": [
    {
      "name": "Lumu Footer Products"
    }
  ]
}
{% endschema %}
