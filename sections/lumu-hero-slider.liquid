{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

<style>
  @media (prefers-reduced-motion: reduce) {
    .lumu-slider__track { transition: none !important; }
    .lumu-slider__slide * { animation: none !important; transition: none !important; }
  }

  .lumu-slider { position: relative; overflow: hidden; border-radius: 0; }

  .lumu-slider__track {
    display: flex;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lumu-slider__slide {
    min-width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 580px;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
  }

  @media screen and (min-width: 1400px) {
    .lumu-slider__slide { min-height: 660px; }
  }

  .lumu-slider__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 8, 30, 0.75) 0%,
      rgba(26, 10, 60, 0.55) 50%,
      rgba(10, 8, 30, 0.4) 100%
    );
    z-index: 1;
  }

  /* Animated shimmer across overlay */
  .lumu-slider__overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(133, 119, 199, 0) 30%,
      rgba(133, 119, 199, 0.12) 50%,
      rgba(133, 119, 199, 0) 70%
    );
    background-size: 200% 100%;
    animation: sliderShimmer 6s ease-in-out infinite;
  }

  @keyframes sliderShimmer {
    0%, 100% { background-position: 200% 0; }
    50% { background-position: -200% 0; }
  }

  .lumu-slider__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    max-width: 800px;
    padding: 48px 24px;
    animation: slideContentIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  @keyframes slideContentIn {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lumu-slider__eyebrow {
    display: inline-block;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(164, 145, 240, 1);
    background: rgba(133, 119, 199, 0.18);
    border: 1px solid rgba(133, 119, 199, 0.35);
    border-radius: 50px;
    padding: 6px 18px;
    margin-bottom: 20px;
    backdrop-filter: blur(8px);
  }

  .lumu-slider__content h2 {
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 900;
    margin-bottom: 20px;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #ffffff;
    text-shadow: 0 4px 40px rgba(0,0,0,0.5);
  }

  .lumu-slider__content h2 em {
    font-style: normal;
    background: linear-gradient(135deg, #a491f0, #e0b3ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lumu-slider__content p {
    font-size: clamp(1.4rem, 2.2vw, 1.85rem);
    margin-bottom: 36px;
    line-height: 1.65;
    color: rgba(255,255,255,0.88);
    text-shadow: 0 2px 16px rgba(0,0,0,0.4);
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
  }

  .lumu-slider__cta-group {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .lumu-slider__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 15px 38px;
    background: linear-gradient(135deg, #8577C7, #6153a7);
    color: white;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1.5rem;
    text-decoration: none;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
    box-shadow: 0 6px 24px rgba(97, 83, 167, 0.45);
    position: relative;
    overflow: hidden;
  }

  .lumu-slider__btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.2) 50%, rgba(255,255,255,0) 100%);
    transform: skewX(-20deg);
    animation: btnShine 5s infinite;
  }

  @keyframes btnShine {
    0% { left: -100%; }
    25% { left: 200%; }
    100% { left: 200%; }
  }

  .lumu-slider__btn:hover {
    background: linear-gradient(135deg, #9d8de0, #7464c0);
    transform: translateY(-3px);
    box-shadow: 0 10px 32px rgba(97, 83, 167, 0.6);
  }

  .lumu-slider__btn--outline {
    background: rgba(255,255,255,0.1);
    border: 2px solid rgba(255,255,255,0.5);
    color: white;
    box-shadow: none;
    backdrop-filter: blur(8px);
  }

  .lumu-slider__btn--outline::before { display: none; }

  .lumu-slider__btn--outline:hover {
    background: rgba(255,255,255,0.22);
    border-color: white;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(255,255,255,0.15);
  }

  /* Navigation dots */
  .lumu-slider__nav {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .lumu-slider__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    border: none;
    cursor: pointer;
    transition: all 0.4s ease;
    padding: 0;
  }

  .lumu-slider__dot.active {
    background: white;
    width: 28px;
    border-radius: 4px;
  }

  /* Arrow buttons */
  .lumu-slider__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    font-size: 18px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(12px);
  }

  .lumu-slider__arrow:hover {
    background: rgba(133, 119, 199, 0.5);
    border-color: rgba(133, 119, 199, 0.6);
    transform: translateY(-50%) scale(1.08);
  }

  .lumu-slider__arrow--prev { left: 24px; }
  .lumu-slider__arrow--next { right: 24px; }

  /* Slide progress bar */
  .lumu-slider__progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    background: linear-gradient(90deg, #8577C7, #a491f0);
    width: 0%;
    z-index: 10;
    transition: width linear;
    border-radius: 0 2px 2px 0;
  }

  /* Badge/pill decoration */
  .lumu-slider__badge {
    position: absolute;
    top: 28px;
    right: 28px;
    z-index: 10;
    background: rgba(133, 119, 199, 0.25);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(133, 119, 199, 0.4);
    border-radius: 12px;
    padding: 10px 18px;
    color: white;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .lumu-slider__badge-dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    animation: pulse-green 2s infinite;
  }

  @keyframes pulse-green {
    0%, 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.6); }
    50% { box-shadow: 0 0 0 6px rgba(16,185,129,0); }
  }

  @media (max-width: 749px) {
    .lumu-slider__slide { min-height: 480px; }
    .lumu-slider__content { padding: 32px 16px; }
    .lumu-slider__btn { padding: 12px 24px; font-size: 1.3rem; }
    .lumu-slider__btn--outline { display: none; }
    .lumu-slider__arrow { width: 38px; height: 38px; font-size: 14px; }
    .lumu-slider__arrow--prev { left: 12px; }
    .lumu-slider__arrow--next { right: 12px; }
    .lumu-slider__badge { top: 12px; right: 12px; font-size: 1.1rem; padding: 8px 12px; }
  }
</style>

<div class="lumu-slider" id="LumuSlider" aria-label="Featured promotions">
  <div class="lumu-slider__track" id="LumuSliderTrack">

    <!-- Slide 1: Main brand hero -->
    <div class="lumu-slider__slide" style="background-image: url('{{ 'lumu-hero-1.png' | asset_url }}');" role="group" aria-label="Slide 1 of 3">
      <div class="lumu-slider__overlay"></div>
      <div class="lumu-slider__content">
        <span class="lumu-slider__eyebrow">🇬🇧 Free UK Delivery on Orders Over £40</span>
        <h2>Your Premium Lifestyle,<br><em>Delivered to Your Door</em></h2>
        <p>Shop 100+ curated tech gadgets, home essentials, health & beauty products — fast tracked delivery across the UK & Europe.</p>
        <div class="lumu-slider__cta-group">
          <a href="{{ routes.all_products_collection_url }}" class="lumu-slider__btn">Shop Now →</a>
          <a href="{{ routes.collections_url }}" class="lumu-slider__btn lumu-slider__btn--outline">Browse Collections</a>
        </div>
      </div>
    </div>

    <!-- Slide 2: Tech & Gadgets -->
    <div class="lumu-slider__slide" style="background-image: url('{{ 'lumu-hero-2-premium.png' | asset_url }}');" role="group" aria-label="Slide 2 of 3">
      <div class="lumu-slider__overlay"></div>
      <div class="lumu-slider__content">
        <span class="lumu-slider__eyebrow">⚡ New Arrivals — Tech & Smart Gadgets</span>
        <h2>The <em>Future of Tech</em><br>Is Here</h2>
        <p>Premium earbuds, wireless chargers, smart home devices & more. All 100% authentic — at prices you'll love.</p>
        <div class="lumu-slider__cta-group">
          <a href="{{ routes.collections_url }}/tech-smart-gadgets" class="lumu-slider__btn">Shop Electronics</a>
        </div>
      </div>
    </div>

    <!-- Slide 3: Home & Beauty -->
    <div class="lumu-slider__slide" style="background-image: url('{{ 'lumu-hero-3-premium.png' | asset_url }}');" role="group" aria-label="Slide 3 of 3">
      <div class="lumu-slider__overlay"></div>
      <div class="lumu-slider__content">
        <span class="lumu-slider__eyebrow">🏡 Transform Your Home & Glow Up</span>
        <h2>Premium Home &<br><em>Beauty Essentials</em></h2>
        <p>From salon-grade beauty tools to smart kitchen gadgets — everything you need to elevate your everyday lifestyle.</p>
        <div class="lumu-slider__cta-group">
          <a href="{{ routes.collections_url }}/home-kitchen-essentials" class="lumu-slider__btn">Shop Home</a>
          <a href="{{ routes.collections_url }}/health-beauty" class="lumu-slider__btn lumu-slider__btn--outline">Shop Beauty</a>
        </div>
      </div>
    </div>

  </div>

  <!-- Live indicator badge -->
  <div class="lumu-slider__badge">
    <span class="lumu-slider__badge-dot"></span>
    UK & EU Delivery
  </div>

  <button class="lumu-slider__arrow lumu-slider__arrow--prev" onclick="lumuSlide(-1)" aria-label="Previous slide">&#10094;</button>
  <button class="lumu-slider__arrow lumu-slider__arrow--next" onclick="lumuSlide(1)" aria-label="Next slide">&#10095;</button>

  <div class="lumu-slider__nav" role="tablist" aria-label="Slide navigation">
    <button class="lumu-slider__dot active" onclick="lumuGoTo(0)" role="tab" aria-selected="true" aria-label="Go to slide 1"></button>
    <button class="lumu-slider__dot" onclick="lumuGoTo(1)" role="tab" aria-selected="false" aria-label="Go to slide 2"></button>
    <button class="lumu-slider__dot" onclick="lumuGoTo(2)" role="tab" aria-selected="false" aria-label="Go to slide 3"></button>
  </div>

  <div class="lumu-slider__progress" id="LumuSliderProgress"></div>
</div>

<script>
  (function () {
    const INTERVAL = 5500;
    let current = 0;
    const total = 3;
    const track = document.getElementById('LumuSliderTrack');
    const dots = document.querySelectorAll('.lumu-slider__dot');
    const progress = document.getElementById('LumuSliderProgress');
    let autoTimer = null;
    let progressTimer = null;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function startProgress() {
      if (reducedMotion) return;
      if (progress) {
        progress.style.transition = 'none';
        progress.style.width = '0%';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            progress.style.transition = 'width ' + INTERVAL + 'ms linear';
            progress.style.width = '100%';
          });
        });
      }
    }

    function updateSlider() {
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach((d, i) => {
        d.classList.toggle('active', i === current);
        d.setAttribute('aria-selected', i === current ? 'true' : 'false');
      });
      startProgress();
    }

    window.lumuSlide = function (dir) {
      current = (current + dir + total) % total;
      updateSlider();
      resetAuto();
    };

    window.lumuGoTo = function (idx) {
      current = idx;
      updateSlider();
      resetAuto();
    };

    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => { window.lumuSlide(1); }, INTERVAL);
    }

    if (!reducedMotion) {
      updateSlider();
      resetAuto();
    }

    // Pause on hover
    const slider = document.getElementById('LumuSlider');
    slider.addEventListener('mouseenter', () => clearInterval(autoTimer));
    slider.addEventListener('mouseleave', () => resetAuto());

    // Swipe support
    let touchStartX = 0;
    slider.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    slider.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) window.lumuSlide(diff > 0 ? 1 : -1);
    }, { passive: true });
  })();
</script>

