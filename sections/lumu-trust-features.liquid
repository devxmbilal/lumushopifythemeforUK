<style>
  /* ============ LUMU TRUST FEATURES — UK Edition ============ */
  .lumu-trust {
    background: linear-gradient(135deg, #8577C7 0%, #5341a0 50%, #3a2880 100%);
    padding: 72px 0;
    position: relative;
    overflow: hidden;
  }

  .lumu-trust::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 350px; height: 350px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    pointer-events: none;
  }

  .lumu-trust::after {
    content: '';
    position: absolute;
    bottom: -60px; left: -60px;
    width: 260px; height: 260px;
    border-radius: 50%;
    background: rgba(255,255,255,0.03);
    pointer-events: none;
  }

  .lumu-trust__title {
    text-align: center;
    margin-bottom: 52px;
    position: relative;
    padding-bottom: 20px;
  }

  .lumu-trust__title-eyebrow {
    display: block;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-bottom: 10px;
  }

  .lumu-trust__title h2 {
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    font-weight: 900;
    color: white;
    letter-spacing: -0.02em;
  }

  .lumu-trust__title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 3px;
    background: rgba(255,255,255,0.45);
    border-radius: 4px;
  }

  .lumu-trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }

  .lumu-trust__card {
    background: rgba(255,255,255,0.09);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.13);
    border-radius: 20px;
    padding: 36px 24px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .lumu-trust__card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(255,255,255,0.05), rgba(255,255,255,0.5), rgba(255,255,255,0.05));
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .lumu-trust__card:hover {
    background: rgba(255,255,255,0.16);
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.2);
  }

  .lumu-trust__card:hover::before { opacity: 1; }

  .lumu-trust__icon {
    width: 68px;
    height: 68px;
    margin: 0 auto 20px;
    background: rgba(255,255,255,0.12);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s ease;
  }

  .lumu-trust__card:hover .lumu-trust__icon {
    background: rgba(255,255,255,0.22);
    transform: scale(1.1);
  }

  .lumu-trust__icon svg {
    width: 30px;
    height: 30px;
    color: white;
    stroke: white;
    fill: none;
  }

  .lumu-trust__card-title {
    font-size: 1.65rem;
    font-weight: 800;
    color: white;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .lumu-trust__card-text {
    font-size: 1.35rem;
    color: rgba(255,255,255,0.78);
    line-height: 1.6;
  }

  @media (max-width: 989px) {
    .lumu-trust__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 749px) {
    .lumu-trust { padding: 52px 0; }
    .lumu-trust__grid { grid-template-columns: 1fr; gap: 16px; padding: 0 16px; }
    .lumu-trust__card { padding: 24px 20px; border-radius: 16px; }
    .lumu-trust__icon { width: 52px; height: 52px; border-radius: 14px; }
    .lumu-trust__icon svg { width: 24px; height: 24px; }
    .lumu-trust__card-title { font-size: 1.45rem; }
    .lumu-trust__card-text { font-size: 1.2rem; }
  }
</style>

<div class="lumu-trust">
  <div class="lumu-trust__title">
    <span class="lumu-trust__title-eyebrow">The Lumu Advantage</span>
    <h2>Why Shop With Lumu?</h2>
  </div>

  <div class="lumu-trust__grid">
    <!-- Free UK Shipping -->
    <div class="lumu-trust__card">
      <div class="lumu-trust__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      </div>
      <div class="lumu-trust__card-title">Free UK Delivery</div>
      <div class="lumu-trust__card-text">Free tracked delivery on all orders over £40. Next-day dispatch available on most items — delivered straight to your door.</div>
    </div>

    <!-- Quality Promise -->
    <div class="lumu-trust__card">
      <div class="lumu-trust__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
        </svg>
      </div>
      <div class="lumu-trust__card-title">Quality Guaranteed</div>
      <div class="lumu-trust__card-text">Every product is hand-picked and quality checked. Not happy? Our simple 7-day returns process has you covered — no questions asked.</div>
    </div>

    <!-- Secure Checkout -->
    <div class="lumu-trust__card">
      <div class="lumu-trust__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
        </svg>
      </div>
      <div class="lumu-trust__card-title">100% Secure Checkout</div>
      <div class="lumu-trust__card-text">Shop with total confidence using Visa, Mastercard, PayPal or Shop Pay. All transactions are SSL-encrypted and fully protected.</div>
    </div>

    <!-- 24/7 Support -->
    <div class="lumu-trust__card">
      <div class="lumu-trust__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <div class="lumu-trust__card-title">Friendly UK Support</div>
      <div class="lumu-trust__card-text">Our dedicated customer care team is available 7 days a week via email and live chat. We're always here to help you.</div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Lumu Trust Features",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
