<style>
  .lumu-cats { padding: 60px 0; background: #F7F5FC; }
  .lumu-cats__title {
    text-align: center; margin-bottom: 40px; position: relative; padding-bottom: 16px;
  }
  .lumu-cats__title h2 {
    font-size: 3rem; font-weight: 800; color: #121212; letter-spacing: -0.02em;
  }
  .lumu-cats__title::after {
    content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 50px; height: 3px; background: linear-gradient(90deg, #8577C7, #a491f0); border-radius: 3px;
  }
  .lumu-cats__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
    max-width: 1200px; margin: 0 auto; padding: 0 20px;
  }
  .lumu-cat-card {
    background: white; border-radius: 16px; overflow: hidden;
    text-decoration: none; color: inherit;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    display: flex; flex-direction: column;
  }
  .lumu-cat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(133, 119, 199, 0.18);
  }
  .lumu-cat-card__img {
    width: 100%; aspect-ratio: 4/3; object-fit: cover;
    transition: transform 0.5s ease;
  }
  .lumu-cat-card:hover .lumu-cat-card__img { transform: scale(1.05); }
  .lumu-cat-card__img-wrap { overflow: hidden; }
  .lumu-cat-card__body { padding: 20px; text-align: center; }
  .lumu-cat-card__icon {
    width: 40px; height: 40px; margin: 0 auto 10px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(133, 119, 199, 0.1); border-radius: 12px; color: #8577C7;
  }
  .lumu-cat-card__icon svg { width: 22px; height: 22px; }
  .lumu-cat-card__name { font-size: 1.6rem; font-weight: 700; margin-bottom: 4px; color: #121212; }
  .lumu-cat-card__desc { font-size: 1.3rem; color: #666; line-height: 1.5; margin-bottom: 10px; }
  .lumu-cat-card__link {
    font-size: 1.3rem; color: #8577C7; font-weight: 600;
    display: inline-flex; align-items: center; gap: 4px;
    transition: gap 0.3s ease;
  }
  .lumu-cat-card:hover .lumu-cat-card__link { gap: 8px; }
  .lumu-cats__cta { text-align: center; margin-top: 40px; }
  .lumu-cats__cta a {
    display: inline-block; padding: 14px 36px;
    background: #8577C7; color: white; border-radius: 8px;
    font-weight: 700; font-size: 1.5rem; text-decoration: none;
    transition: all 0.3s ease; letter-spacing: 0.03em;
  }
  .lumu-cats__cta a:hover {
    background: #6153a7; transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(133,119,199,0.4);
  }
  @media (max-width: 989px) { .lumu-cats__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 549px) {
    .lumu-cats__grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .lumu-cat-card__body { padding: 14px; }
    .lumu-cat-card__name { font-size: 1.4rem; }
    .lumu-cats__title h2 { font-size: 2.2rem; }
  }
</style>

<div class="lumu-cats">
