<style>
  /* ============ LUMU CATEGORIES — Premium UK Edition ============ */
  .lumu-cats {
    padding: 72px 0;
    background: linear-gradient(180deg, #f0edfb 0%, #fafafa 100%);
    position: relative;
    overflow: hidden;
  }

  .lumu-cats::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(133,119,199,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .lumu-cats__title {
    text-align: center;
    margin-bottom: 48px;
    position: relative;
    padding-bottom: 20px;
  }

  .lumu-cats__title-eyebrow {
    display: inline-block;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8577C7;
    margin-bottom: 12px;
  }

  .lumu-cats__title h2 {
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 900;
    color: #0f0e2a;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .lumu-cats__title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 4px;
    background: linear-gradient(90deg, #8577C7, #a491f0);
    border-radius: 4px;
  }

  .lumu-cats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .lumu-cat-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(133,119,199,0.08);
    position: relative;
  }

  .lumu-cat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(133,119,199,0.04), rgba(164,145,240,0.04));
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
    pointer-events: none;
  }

  .lumu-cat-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 48px rgba(133, 119, 199, 0.22);
    border-color: rgba(133,119,199,0.2);
  }

  .lumu-cat-card:hover::before { opacity: 1; }

  .lumu-cat-card__img-wrap {
    overflow: hidden;
    position: relative;
  }

  .lumu-cat-card__img-wrap::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to top, rgba(255,255,255,0.5), transparent);
    pointer-events: none;
  }

  .lumu-cat-card__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
  }

  .lumu-cat-card:hover .lumu-cat-card__img { transform: scale(1.08); }

  .lumu-cat-card__body {
    padding: 22px 24px 26px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .lumu-cat-card__icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(133,119,199,0.12), rgba(164,145,240,0.15));
    border-radius: 14px;
    color: #8577C7;
    transition: all 0.35s ease;
  }

  .lumu-cat-card:hover .lumu-cat-card__icon {
    background: linear-gradient(135deg, #8577C7, #a491f0);
    color: white;
    transform: scale(1.1) rotate(-4deg);
  }

  .lumu-cat-card__icon svg { width: 24px; height: 24px; }

  .lumu-cat-card__name {
    font-size: 1.7rem;
    font-weight: 800;
    margin-bottom: 6px;
    color: #0f0e2a;
    letter-spacing: -0.01em;
  }

  .lumu-cat-card__desc {
    font-size: 1.3rem;
    color: #6b6b80;
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .lumu-cat-card__link {
    font-size: 1.3rem;
    color: #8577C7;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.3s ease, color 0.3s ease;
  }

  .lumu-cat-card:hover .lumu-cat-card__link {
    gap: 10px;
    color: #6153a7;
  }

  .lumu-cats__cta {
    text-align: center;
    margin-top: 48px;
  }

  .lumu-cats__cta a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 40px;
    background: linear-gradient(135deg, #8577C7, #6153a7);
    color: white;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1.5rem;
    text-decoration: none;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
    box-shadow: 0 6px 20px rgba(133,119,199,0.35);
  }

  .lumu-cats__cta a:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(133,119,199,0.5);
  }

  @media (max-width: 989px) {
    .lumu-cats__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 549px) {
    .lumu-cats { padding: 48px 0; }
    .lumu-cats__grid { grid-template-columns: 1fr; gap: 16px; padding: 0 16px; }
    .lumu-cat-card__body { padding: 16px 18px 20px; }
    .lumu-cat-card__name { font-size: 1.5rem; }
  }
</style>

