{%- style -%}
.lumu-reviews-section {
  padding: 80px 0;
  background: var(--gradient-background);
  overflow: hidden;
}

.lumu-reviews-header {
  text-align: center;
  margin-bottom: 50px;
}

.lumu-reviews-header h2 {
  font-size: 3.6rem;
  color: var(--lumu-purple, #6153a7);
  font-weight: 900;
  margin-bottom: 15px;
  letter-spacing: -1px;
}

.lumu-reviews-header p {
  font-size: 1.8rem;
  color: rgba(var(--color-foreground), 0.7);
  max-width: 600px;
  margin: 0 auto;
}

.lumu-reviews-wrapper {
  display: flex;
  overflow: hidden;
  white-space: nowrap;
  width: 100%;
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 15px;
  position: relative;
  /* Premium fade-out mask on both edges */
  -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
}

.lumu-marquee-track {
  display: inline-flex;
  animation: scrollMarquee 55s linear infinite;
  padding-left: 20px;
}

.lumu-marquee-track.reverse-track {
  animation: scrollMarqueeReverse 50s linear infinite;
}

.lumu-reviews-wrapper:hover .lumu-marquee-track {
  animation-play-state: paused;
}

@keyframes scrollMarquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}

@keyframes scrollMarqueeReverse {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(0); }
}

.lumu-review-card {
  width: 350px;
  background: rgb(var(--color-background));
  border-radius: 16px;
  padding: 28px;
  margin-right: 24px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.06);
  white-space: normal;
  display: inline-flex;
  flex-direction: column;
  border: 1px solid rgba(var(--color-foreground), 0.05);
  border-top: 5px solid var(--lumu-purple, #6153a7);
  transition: transform 0.3s ease;
}

.lumu-review-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 15px 40px rgba(97, 83, 167, 0.15);
}

.lumu-review-stars {
  color: #f59e0b; /* Golden Yellow */
  font-size: 2rem;
  margin-bottom: 15px;
  letter-spacing: 2px;
}

.lumu-review-text {
  font-size: 1.5rem;
  color: rgba(var(--color-foreground), 0.85);
  line-height: 1.6;
  margin-bottom: 20px;
  font-style: italic;
}

.lumu-review-footer {
  margin-top: auto;
  display: flex;
  align-items: center;
}

.lumu-review-avatar {
  width: 40px;
  height: 40px;
  background: var(--lumu-purple, #6153a7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  font-size: 1.4rem;
  margin-right: 12px;
}

.lumu-review-author-info {
  display: flex;
  flex-direction: column;
}

.lumu-review-author {
  font-weight: 800;
  color: rgb(var(--color-foreground));
  font-size: 1.4rem;
}

.lumu-review-buyer {
  font-size: 1.2rem;
  color: #10b981; /* Emerald green */
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4px;
}

@media screen and (max-width: 749px) {
  .lumu-reviews-section { padding: 50px 0; }
  .lumu-reviews-header h2 { font-size: 2.8rem; }
  .lumu-review-card { width: 300px; padding: 20px; }
  .lumu-marquee-track { animation-duration: 40s; }
  .lumu-marquee-track.reverse-track { animation-duration: 35s; }
}
{%- endstyle -%}

